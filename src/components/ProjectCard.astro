---
import type { Project } from '../data/projects';

export interface Props {
  project: Project;
  fullWidth?: boolean;
}

const { project, fullWidth = false } = Astro.props;
---

<div class={`reveal glass-card glow-border p-6 flex flex-col gap-4 ${fullWidth ? 'col-span-full' : ''}`}>
  <!-- Header -->
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <h3 class="font-bold text-lg leading-tight" style="color: var(--text-primary);">{project.title}</h3>
      <p class="mt-1 text-sm" style="color: var(--text-secondary);">{project.description}</p>
    </div>
    {project.github && (
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 p-2 rounded-md transition-colors"
        style="color: var(--text-muted);"
        aria-label="View on GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    )}
  </div>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {project.tags.map(tag => (
      <span class="skill-tag">{tag}</span>
    ))}
  </div>

  <!-- Demo embed (iframe) -->
  {project.demo && project.demoType === 'iframe' && (
    <div class="mt-2">
      <div class="relative w-full rounded-lg overflow-hidden border" style="padding-bottom: 56.25%; border-color: var(--border);">
        <div class="absolute inset-0 flex items-center justify-center" style="background: var(--card);">
          <span class="text-xs font-mono" style="color: var(--text-muted);">Loading demo…</span>
        </div>
        <iframe
          src={project.demo}
          title={project.title + ' demo'}
          class="absolute inset-0 w-full h-full rounded-lg"
          loading="lazy"
          allow="accelerometer; camera; encrypted-media; microphone"
          sandbox="allow-forms allow-modals allow-popups allow-same-origin allow-scripts"
        ></iframe>
      </div>
      <a
        href={project.demo}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center gap-1 text-xs font-mono transition-colors"
        style="color: var(--text-muted);"
      >
        Open in new tab ↗
      </a>
    </div>
  )}

  <!-- Demo link -->
  {project.demo && project.demoType === 'link' && (
    <a
      href={project.demo}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-md text-sm font-semibold transition-all hover:opacity-90 self-start"
      style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); color: white;"
    >
      Try it live →
    </a>
  )}

  <!-- Screenshot -->
  {project.screenshot && (
    <a href={project.screenshot} target="_blank" rel="noopener noreferrer" class="block relative rounded-lg overflow-hidden border" style="border-color: var(--border);">
      <img src={project.screenshot} alt={project.title + ' screenshot'} class="w-full h-auto" loading="lazy" />
    </a>
  )}

  <!-- Bullets -->
  {(!project.demo || project.demoType !== 'iframe') && (
    <ul class="flex flex-col gap-1.5">
      {project.bullets.map(bullet => (
        <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
          <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background: #8b5cf6;"></span>
          {bullet}
        </li>
      ))}
    </ul>
  )}

  <!-- Metrics -->
  {project.metrics && (
    <div class="mt-auto pt-2 border-t" style="border-color: var(--border);">
      <span class="gradient-text font-mono text-sm font-semibold">{project.metrics}</span>
    </div>
  )}
</div>
