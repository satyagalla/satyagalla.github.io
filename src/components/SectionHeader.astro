---
export interface Props {
  number: string;
  title: string;
}
const { number, title } = Astro.props;
---

<div class="reveal flex items-center gap-4 mb-12">
  <span class="font-mono text-sm font-medium shrink-0" style="color: var(--text-muted);">{number}</span>
  <h2 class="text-2xl md:text-3xl font-bold shrink-0" style="color: var(--text-primary);">{title}</h2>
  <div class="flex-1 h-px" style="background: var(--border);"></div>
</div>
