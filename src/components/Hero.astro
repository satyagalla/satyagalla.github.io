<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
  <!-- Gradient blobs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute w-[600px] h-[600px] rounded-full blur-[120px]" style="background: #8b5cf6; opacity: 0.10; top: -100px; left: -100px; animation: floatSlow 10s ease-in-out infinite;"></div>
    <div class="absolute w-[500px] h-[500px] rounded-full blur-[100px]" style="background: #06b6d4; opacity: 0.06; bottom: -50px; right: -50px; animation: floatMedium 8s ease-in-out infinite;"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full blur-[80px]" style="background: #6366f1; opacity: 0.05; top: 40%; left: 50%; transform: translate(-50%, -50%); animation: floatSlow 12s ease-in-out infinite reverse;"></div>
  </div>

  <!-- Canvas -->
  <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" aria-hidden="true"></canvas>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Beacon -->
    <div class="reveal inline-flex items-center gap-2 mb-8 px-3 py-1.5 rounded-full text-sm font-mono border" style="border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.05); color: #22c55e;">
      <span class="w-2 h-2 rounded-full bg-green-500 beacon-pulse inline-block"></span>
      Open to opportunities
    </div>

    <!-- Name -->
    <h1 class="reveal text-5xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-4" style="color: var(--text-primary);">
      Satya Akhil Galla
    </h1>

    <!-- Tagline -->
    <p class="reveal text-2xl md:text-3xl font-semibold mb-6">
      <span class="gradient-text">I architect AI systems</span>
      <span style="color: var(--text-secondary);"> — from research to production.</span>
    </p>

    <!-- Summary -->
    <p class="reveal text-lg max-w-2xl mx-auto mb-10 leading-relaxed" style="color: var(--text-secondary);">
      ML Engineer with published research at IEEE &amp; NASA. I build production LLM systems, agentic pipelines,
      and ship things that work — not just demos.
    </p>

    <!-- CTAs -->
    <div class="reveal flex flex-wrap items-center justify-center gap-4">
      <a
        href="/Satya_Galla_Resume_13.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all hover:opacity-90 hover:scale-105"
        style="background: linear-gradient(135deg, #8b5cf6, #06b6d4); color: white;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Resume
      </a>
      <a
        href="https://github.com/satyagalla"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm border transition-all hover:scale-105 glow-border"
        style="border-color: var(--border); color: var(--text-primary); background: var(--card);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/satya-galla"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm border transition-all hover:scale-105 glow-border"
        style="border-color: var(--border); color: var(--text-primary); background: var(--card);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href="https://scholar.google.com/citations?user=gLqht5wAAAAJ&hl=en"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm border transition-all hover:scale-105 glow-border"
        style="border-color: var(--border); color: var(--text-primary); background: var(--card);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/></svg>
        Scholar
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-xs" style="color: var(--text-muted); animation: bounceHint 2s ease-in-out infinite;">
    ↓ scroll
  </div>
</section>

<style>
  @keyframes floatSlow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -30px) scale(1.05); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }
  @keyframes floatMedium {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(calc(-50% - 40px), calc(-50% - 20px)) scale(1.05); }
  }
  @keyframes bounceHint {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
  @keyframes beaconPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(1.4); }
  }
  .beacon-pulse { animation: beaconPulse 2s ease-in-out infinite; }
</style>

<script is:inline>
  (function () {
    const canvas = document.getElementById('hero-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let nodes = [];
    let animFrame;
    let mouseX = -9999, mouseY = -9999;
    let paused = false;

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }

    function initNodes() {
      const count = window.innerWidth < 768 ? 40 : 80;
      nodes = [];
      for (let i = 0; i < count; i++) {
        nodes.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          radius: Math.random() * 2 + 1,
          color: Math.random() > 0.5 ? 'violet' : 'cyan',
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
      const threshold = 120;

      // Edges
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < threshold) {
            const alpha = (1 - dist / threshold) * (isDark ? 0.08 : 0.12);
            ctx.beginPath();
            ctx.moveTo(nodes[i].x, nodes[i].y);
            ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.strokeStyle = isDark ? `rgba(180,160,255,${alpha})` : `rgba(100,80,200,${alpha})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      // Nodes
      for (const node of nodes) {
        const dx = node.x - mouseX;
        const dy = node.y - mouseY;
        const distToMouse = Math.sqrt(dx * dx + dy * dy);
        const glowRadius = 80;
        const glowing = distToMouse < glowRadius;
        const alpha = glowing
          ? 0.5 + (1 - distToMouse / glowRadius) * 0.5
          : (isDark ? 0.3 : 0.5);

        ctx.beginPath();
        ctx.arc(node.x, node.y, node.radius + (glowing ? 1 : 0), 0, Math.PI * 2);
        if (node.color === 'violet') {
          ctx.fillStyle = `rgba(139, 92, 246, ${alpha})`;
        } else {
          ctx.fillStyle = `rgba(6, 182, 212, ${alpha})`;
        }
        ctx.fill();
      }
    }

    function update() {
      for (const node of nodes) {
        // Slight mouse attraction
        const dx = mouseX - node.x;
        const dy = mouseY - node.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100 && dist > 0) {
          node.vx += (dx / dist) * 0.02;
          node.vy += (dy / dist) * 0.02;
        }

        node.x += node.vx;
        node.y += node.vy;

        // Clamp velocity
        const speed = Math.sqrt(node.vx * node.vx + node.vy * node.vy);
        if (speed > 1.5) { node.vx *= 0.95; node.vy *= 0.95; }

        // Bounce off edges
        if (node.x < 0 || node.x > canvas.width) node.vx *= -1;
        if (node.y < 0 || node.y > canvas.height) node.vy *= -1;
        node.x = Math.max(0, Math.min(canvas.width, node.x));
        node.y = Math.max(0, Math.min(canvas.height, node.y));
      }
    }

    function loop() {
      if (!paused) {
        update();
        draw();
      }
      animFrame = requestAnimationFrame(loop);
    }

    resize();
    initNodes();

    if (prefersReducedMotion) {
      draw();
    } else {
      loop();
    }

    window.addEventListener('resize', () => {
      resize();
      initNodes();
    });

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });

    canvas.addEventListener('mouseleave', () => {
      mouseX = -9999;
      mouseY = -9999;
    });

    // Pause when not visible
    const observer = new IntersectionObserver((entries) => {
      paused = !entries[0].isIntersecting;
    });
    observer.observe(canvas);
  })();
</script>
